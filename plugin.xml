<?xml version="1.0" encoding="UTF-8"?>
<plugin xmlns="http://apache.org/cordova/ns/plugins/1.0"
        id="cordova-plugin-shopy-push"
        version="1.0.0">
    
    <name>ShopyPush</name>
    <description>Plugin que escucha FCM y activa Local Notification</description>
    
    <js-module src="www/ShopyPush.js" name="ShopyPush">
        <clobbers target="ShopyPush" />
    </js-module>
    
    <platform name="android">
        <config-file target="config.xml" parent="/*">
            <feature name="ShopyPush">
                <param name="android-package" value="com.shopy.push.ShopyPushPlugin"/>
            </feature>
        </config-file>
        
        <source-file src="src/android/ShopyPushPlugin.java" target-dir="src/com/shopy/push" />
        
        <!-- Permiso para recibir broadcasts -->
        <config-file target="AndroidManifest.xml" parent="/manifest">
            <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
        </config-file>
    </platform>
</plugin>