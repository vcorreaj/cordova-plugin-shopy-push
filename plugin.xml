<?xml version="1.0" encoding="UTF-8"?>
<plugin xmlns="http://apache.org/cordova/ns/plugins/1.0"
        id="cordova-plugin-shopy-push"
        version="1.0.0">
    
    <name>ShopyPush</name>
    <description>Background service for Android 14+</description>
    
    <js-module src="www/ShopyPush.js" name="ShopyPush">
        <clobbers target="ShopyPush" />
    </js-module>
    
    <platform name="android">
        <config-file target="config.xml" parent="/*">
            <feature name="ShopyPush">
                <param name="android-package" value="com.shopy.push.ShopyPushPlugin"/>
            </feature>
        </config-file>
        
        <source-file src="src/android/ShopyPushPlugin.java" target-dir="src/com/shopy/push" />
        <source-file src="src/android/ShopyPushService.java" target-dir="src/com/shopy/push" />
        
        <config-file target="AndroidManifest.xml" parent="/manifest">
            <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
            <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
            <uses-permission android:name="android.permission.WAKE_LOCK" />
        </config-file>
        
        <config-file target="AndroidManifest.xml" parent="/manifest/application">
            <service
                android:name="com.shopy.push.ShopyPushService"
                android:enabled="true"
                android:exported="false"
                android:foregroundServiceType="dataSync" />
        </config-file>
    </platform>
</plugin>