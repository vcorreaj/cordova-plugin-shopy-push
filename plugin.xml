<?xml version="1.0" encoding="UTF-8"?>
<plugin xmlns="http://apache.org/cordova/ns/plugins/1.0"
        id="cordova-plugin-shopy-push"
        version="1.0.0">
    
    <name>ShopyPush</name>
    <description>Plugin personalizado que mantiene FCM activo y maneja notificaciones en Android 14+</description>
    <license>MIT</license>
    
    <js-module src="www/ShopyPush.js" name="ShopyPush">
        <clobbers target="ShopyPush" />
    </js-module>
    
    <platform name="android">
        <config-file target="config.xml" parent="/*">
            <feature name="ShopyPush">
                <param name="android-package" value="com.shopy.push.ShopyPushPlugin"/>
            </feature>
        </config-file>
        
        <!-- Archivos fuente -->
        <source-file src="src/android/ShopyPushPlugin.java" target-dir="src/com/shopy/push" />
        <source-file src="src/android/ShopyPushService.java" target-dir="src/com/shopy/push" />
        
        <!-- Dependencias de Firebase (necesarias para FCM) -->
        <framework src="com.google.firebase:firebase-messaging:23.4.0" />
        <framework src="com.google.firebase:firebase-common:20.4.0" />
        
        <!-- PERMISOS PARA ANDROID 14+ -->
        <config-file target="AndroidManifest.xml" parent="/manifest">
            <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
            <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
            <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
            <uses-permission android:name="android.permission.WAKE_LOCK" />
            <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
        </config-file>
        
        <!-- 🔥 SERVICIO PERSONALIZADO (con tipo dataSync para Android 14) -->
        <config-file target="AndroidManifest.xml" parent="/manifest/application">
            <service
                android:name="com.shopy.push.ShopyPushService"
                android:enabled="true"
                android:exported="false"
                android:foregroundServiceType="dataSync">
                <intent-filter>
                    <action android:name="com.google.firebase.MESSAGING_EVENT" />
                </intent-filter>
            </service>
        </config-file>
    </platform>
</plugin>